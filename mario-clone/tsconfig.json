{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["node", "vite/client"],
    "paths": {
      "@cubeforge/core":     ["../../cubeforge/packages/core/src/index.ts"],
      "@cubeforge/input":    ["../../cubeforge/packages/input/src/index.ts"],
      "@cubeforge/renderer": ["../../cubeforge/packages/renderer/src/index.ts"],
      "@cubeforge/physics":  ["../../cubeforge/packages/physics/src/index.ts"],
      "@cubeforge/react":    ["../../cubeforge/packages/react/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
